<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shipment_bill_warning_wizard_form" model="ir.ui.view">
        <field name="name">shipment.bill.warning.wizard.form</field>
        <field name="model">shipment.bill.warning.wizard</field>
        <field name="arch" type="xml">
            <form string="Shipment Not Yet Arrived">
                <div class="o_form_sheet">
                    <div class="alert alert-warning mb-3" role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Warning: Shipment Has Not Arrived</strong>
                    </div>
                    <field name="warning_message" widget="text" readonly="1"
                           style="white-space: pre-wrap; font-size: 13px;"/>
                </div>
                <footer>
                    <button name="action_proceed"
                            string="Proceed Anyway"
                            type="object"
                            class="btn-warning"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
