<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="report_positioned_image_company_rule" model="ir.rule">
        <field name="name">Report Positioned Image: multi-company</field>
        <field name="model_id" ref="model_report_positioned_image" />
        <field name="domain_force">[
            '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
        ]</field>
    </record>
</odoo>
