<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_lc_cancel_wizard_form" model="ir.ui.view">
        <field name="name">lc.cancel.wizard.form</field>
        <field name="model">lc.cancel.wizard</field>
        <field name="arch" type="xml">

            <form string="Cancel LC">

                <sheet>

                    <div class="alert alert-danger" role="alert">
                        <strong>Warning!</strong>
                        Cancelling this LC will reverse all related accounting entries.
                        This action cannot be undone.
                    </div>

                    <group>
                        <field name="lc_id" readonly="1"/>
                        <field name="reason"
                               placeholder="Enter cancellation reason..."/>
                    </group>

                </sheet>

                <footer>

                    <button
                        name="action_confirm_cancel"
                        string="Confirm Cancellation"
                        type="object"
                        class="btn-danger"/>

                    <button
                        string="Discard"
                        special="cancel"
                        class="btn-secondary"/>

                </footer>

            </form>

        </field>
    </record>

</odoo>