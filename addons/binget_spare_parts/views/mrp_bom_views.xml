<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ══ BoM form: Model column in component lines ══ -->
    <record id="mrp_bom_form_model_col"
            model="ir.ui.view">
        <field name="name">mrp.bom.form.model.col</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id"
               ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">

            <xpath
                expr="//field[@name='bom_line_ids']/list/field[@name='product_id']"
                position="before">

                <field
                    name="product_model"
                    string="Model"
                    readonly="1"
                    optional="show"/>

            </xpath>

        </field>
    </record>

</data>
</odoo>