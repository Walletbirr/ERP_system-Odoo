msgstr ""
"<code>record_id</code>: ID entero del registro que se está editando, o <code>"
"False</code> si el formulario\n"
"está creando un nuevo registro."

#. module: web_form_banner
#: model_terms:ir.ui.view,arch_db:web_form_banner.view_web_form_banner_rule_form
msgid "<code>time, datetime</code>: Standard Python time/datetime modules."
msgstr "<code>time, datetime</code>: Módulos estándar de Python time/datetime."

#. module: web_form_banner
#: model_terms:ir.ui.view,arch_db:web_form_banner.view_web_form_banner_rule_form
msgid "<code>timezone</code>: <code>pytz.timezone</code> for TZ handling."
msgstr ""
"<code>timezone</code>: <code>pytz.timezone</code> para el manejo de zonas "
"horarias."

#. module: web_form_banner
#: model_terms:ir.ui.view,arch_db:web_form_banner.view_web_form_banner_rule_form
msgid ""
