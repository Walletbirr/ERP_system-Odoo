<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW — FIX #3: local_transport_state column added -->
    <record id="view_shipment_container_list" model="ir.ui.view">
        <field name="name">shipment.container.list</field>
        <field name="model">shipment.container</field>
        <field name="arch" type="xml">
            <list string="Containers">
                <field name="container_number"/>
                <field name="size"/>
                <field name="seal_number"/>
                <field name="shipment_id"/>
                <field name="carrier"/>
                <field name="shipment_state"
                       widget="badge"
                       decoration-info="shipment_state == 'planned'"
                       decoration-warning="shipment_state == 'in_transit'"
                       decoration-success="shipment_state == 'arrived'"/>
                <!-- FIX #3: Local transport delivery status per container -->
                <field name="local_transport_state"
                       widget="badge"
                       decoration-muted="local_transport_state == 'not_assigned'"
                       decoration-info="local_transport_state == 'pending'"
                       decoration-warning="local_transport_state == 'in_transit'"
                       decoration-success="local_transport_state == 'delivered'"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_shipment_container_form" model="ir.ui.view">
        <field name="name">shipment.container.form</field>
        <field name="model">shipment.container</field>
        <field name="arch" type="xml">
            <form string="Container">
                <sheet>
                    <div class="oe_title">
                        <label for="container_number" string="Container"/>
                        <h1><field name="container_number" placeholder="MSCU1234567"/></h1>
                    </div>
                    <group>
                        <group string="Container Details">
                            <field name="size"/>
                            <field name="seal_number"/>
                            <field name="notes"/>
                        </group>
                        <group string="Shipment">
                            <field name="shipment_id"/>
                            <field name="carrier" readonly="1"/>
                            <field name="shipment_state" widget="badge"
                                   decoration-info="shipment_state == 'planned'"
                                   decoration-warning="shipment_state == 'in_transit'"
                                   decoration-success="shipment_state == 'arrived'"/>
                        </group>
                    </group>
                    <group string="Local Transport">
                        <field name="local_transport_state" widget="badge"
                               decoration-muted="local_transport_state == 'not_assigned'"
                               decoration-info="local_transport_state == 'pending'"
                               decoration-warning="local_transport_state == 'in_transit'"
                               decoration-success="local_transport_state == 'delivered'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_shipment_container_search" model="ir.ui.view">
        <field name="name">shipment.container.search</field>
        <field name="model">shipment.container</field>
        <field name="arch" type="xml">
            <search string="Search Containers">
                <field name="container_number" string="Container Number"/>
                <field name="seal_number" string="Seal Number"/>
                <field name="shipment_id" string="Shipment"/>
                <filter name="planned" string="Planned" domain="[('shipment_state','=','planned')]"/>
                <filter name="in_transit" string="In Transit" domain="[('shipment_state','=','in_transit')]"/>
                <filter name="arrived" string="Arrived" domain="[('shipment_state','=','arrived')]"/>
                <separator/>
                <!-- FIX #3: filter by local transport status -->
                <filter name="lt_not_assigned" string="Transport: Not Assigned"
                        domain="[('local_transport_state','=','not_assigned')]"/>
                <filter name="lt_pending" string="Transport: Pending"
                        domain="[('local_transport_state','=','pending')]"/>
                <filter name="lt_in_transit" string="Transport: In Transit"
                        domain="[('local_transport_state','=','in_transit')]"/>
                <filter name="lt_delivered" string="Transport: Delivered"
                        domain="[('local_transport_state','=','delivered')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_size" string="Container Size" context="{'group_by': 'size'}"/>
                    <filter name="group_shipment" string="Shipment" context="{'group_by': 'shipment_id'}"/>
                    <filter name="group_transport_state" string="Transport Status"
                            context="{'group_by': 'local_transport_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- WINDOW ACTION -->
    <record id="action_shipment_container" model="ir.actions.act_window">
        <field name="name">Containers</field>
        <field name="res_model">shipment.container</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_shipment_container_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No containers found.</p>
            <p>Containers are added from within a Shipment record.</p>
        </field>
    </record>

    <menuitem id="menu_container_list" name="Containers" parent="menu_shipment_root"
              action="action_shipment_container" sequence="20"/>

</odoo>
