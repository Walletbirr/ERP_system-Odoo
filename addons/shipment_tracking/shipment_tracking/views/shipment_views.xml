<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_shipment_tracking_list" model="ir.ui.view">
        <field name="name">shipment.tracking.list</field>
        <field name="model">shipment.tracking</field>
        <field name="arch" type="xml">
            <list string="Shipments" default_order="eta asc">
                <field name="reference"/>
                <field name="carrier"/>
                <field name="supplier_id"/>
                <field name="purchase_order_id"/>
                <field name="port_of_loading"/>
                <field name="port_of_discharge"/>
                <field name="etd"/>
                <field name="eta"/>
                <field name="actual_arrival_date"/>
                <field name="container_count"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'planned'"
                       decoration-warning="state == 'in_transit'"
                       decoration-success="state == 'arrived'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_shipment_tracking_form" model="ir.ui.view">
        <field name="name">shipment.tracking.form</field>
        <field name="model">shipment.tracking</field>
        <field name="arch" type="xml">
            <form string="Shipment">
                <header>
                    <button name="action_set_in_transit"
                            string="Depart (Set In Transit)"
                            type="object" class="btn-primary"
                            invisible="state != 'planned'"/>
                    <button name="action_set_arrived"
                            string="Mark Arrived"
                            type="object" class="btn-primary"
                            invisible="state != 'in_transit'"/>
                    <!-- FIX #1: Mark Cleared button removed. Arrived is final. -->
                    <button name="action_reset_to_planned"
                            string="Reset to Planned"
                            type="object" class="btn-secondary"
                            invisible="state != 'in_transit'"/>
                    <button name="action_create_transport_trip"
                            string="Create Transport Trip"
                            type="object" class="btn-primary"
                            invisible="state != 'arrived'"
                            help="Create a local transport trip to move containers to warehouse"/>
                    <!-- FIX #1: statusbar_visible updated — no cleared -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="planned,in_transit,arrived"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-cube"
                                type="object" name="action_view_containers"
                                help="View linked containers">
                            <field name="container_count" string="Containers" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-truck"
                                type="object" name="action_view_transport_trips"
                                invisible="transport_trip_count == 0"
                                help="Local transport trips for this shipment">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="transport_trip_count"/>
                                </span>
                                <span class="o_stat_text">Transport Trips</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="reference" string="Shipment"/>
                        <h1><field name="reference" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Shipment Details">
                            <field name="carrier" placeholder="e.g. Maersk, MSC, CMA CGM"/>
                            <field name="incoterm_id"/>
                            <field name="port_of_loading" placeholder="e.g. Shanghai, China"/>
                            <field name="port_of_discharge" placeholder="e.g. Djibouti"/>
                        </group>
                        <group string="Dates">
                            <!-- FIX #2: ETD and ETA required (enforced in model, asterisk shows automatically) -->
                            <field name="etd"/>
                            <field name="eta"/>
                            <field name="actual_arrival_date"
                                   invisible="state != 'arrived'"/>
                        </group>
                    </group>

                    <group string="Purchase Order">
                        <field name="purchase_order_id"/>
                        <field name="supplier_id" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="po_amount_total" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Containers" name="containers">
                            <field name="container_ids" context="{'default_shipment_id': id}">
                                <list editable="bottom">
                                    <field name="container_number" placeholder="MSCU1234567"/>
                                    <field name="size"/>
                                    <field name="seal_number" placeholder="e.g. SL998877"/>
                                    <field name="notes" placeholder="Optional notes..."/>
                                    <!-- FIX #3: show local transport status in container inline list -->
                                    <field name="local_transport_state"
                                           widget="badge"
                                           decoration-muted="local_transport_state == 'not_assigned'"
                                           decoration-info="local_transport_state == 'pending'"
                                           decoration-warning="local_transport_state == 'in_transit'"
                                           decoration-success="local_transport_state == 'delivered'"
                                           optional="show"/>
                                    <field name="shipment_state"
                                           widget="badge"
                                           decoration-info="shipment_state == 'planned'"
                                           decoration-warning="shipment_state == 'in_transit'"
                                           decoration-success="shipment_state == 'arrived'"
                                           optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes_page">
                            <field name="notes" placeholder="Add internal notes about this shipment..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_shipment_tracking_kanban" model="ir.ui.view">
        <field name="name">shipment.tracking.kanban</field>
        <field name="model">shipment.tracking</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="reference"/>
                <field name="carrier"/>
                <field name="eta"/>
                <field name="container_count"/>
                <field name="supplier_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="fw-bold text-primary"><field name="reference"/></div>
                            <div class="text-muted small">
                                <i class="fa fa-ship me-1"/><field name="carrier"/>
                            </div>
                            <div class="small mt-1">
                                <i class="fa fa-building-o me-1"/><field name="supplier_id"/>
                            </div>
                            <div class="small">
                                <i class="fa fa-calendar me-1"/> ETA: <field name="eta"/>
                            </div>
                            <div class="small">
                                <i class="fa fa-cube me-1"/><field name="container_count"/> containers
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_shipment_tracking_search" model="ir.ui.view">
        <field name="name">shipment.tracking.search</field>
        <field name="model">shipment.tracking</field>
        <field name="arch" type="xml">
            <search string="Search Shipments">
                <field name="reference" string="Reference"/>
                <field name="carrier" string="Carrier"/>
                <field name="purchase_order_id" string="Purchase Order"/>
                <field name="supplier_id" string="Supplier"/>
                <field name="container_ids" string="Container Number"
                       filter_domain="[('container_ids.container_number', 'ilike', self)]"/>
                <separator/>
                <filter name="filter_planned" string="Planned" domain="[('state','=','planned')]"/>
                <filter name="filter_in_transit" string="In Transit" domain="[('state','=','in_transit')]"/>
                <filter name="filter_arrived" string="Arrived" domain="[('state','=','arrived')]"/>
                <separator/>
                <filter name="filter_overdue" string="Overdue (ETA Passed)"
                        domain="[('eta','&lt;', context_today().strftime('%Y-%m-%d')),
                                  ('state','not in',['arrived'])]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_carrier" string="Carrier" context="{'group_by': 'carrier'}"/>
                    <filter name="group_supplier" string="Supplier" context="{'group_by': 'supplier_id'}"/>
                    <filter name="group_eta_month" string="ETA Month" context="{'group_by': 'eta:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- WINDOW ACTION -->
    <record id="action_shipment_tracking" model="ir.actions.act_window">
        <field name="name">Shipments</field>
        <field name="res_model">shipment.tracking</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_shipment_tracking_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first shipment!</p>
            <p>Track import shipments from departure to arrival.</p>
        </field>
    </record>

    <!-- MENUS -->
    <menuitem id="menu_shipment_root" name="Shipment Tracking" sequence="55"
              web_icon="shipment_tracking,static/description/icon.png"/>
    <menuitem id="menu_shipment_list" name="Shipments" parent="menu_shipment_root"
              action="action_shipment_tracking" sequence="10"/>

</odoo>
