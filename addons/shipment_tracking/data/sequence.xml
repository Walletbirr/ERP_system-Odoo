<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_shipment_tracking" model="ir.sequence">
            <field name="name">Shipment Tracking Reference</field>
            <field name="code">shipment.tracking</field>
            <field name="prefix">SHP/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_local_transport_trip" model="ir.sequence">
            <field name="name">Local Transport Trip Reference</field>
            <field name="code">local.transport.trip</field>
            <field name="prefix">TRP/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>


        <record id="seq_shipment_cost" model="ir.sequence">
            <field name="name">Shipment Cost Reference</field>
            <field name="code">shipment.cost</field>
            <field name="prefix">CST/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
