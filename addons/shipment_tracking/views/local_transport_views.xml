<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════
         ASSIGNMENT — FORM VIEW
         Opens when user clicks a truck line inside the trip form.
    ══════════════════════════════════════════════════════════════════ -->
    <record id="view_local_transport_assignment_form" model="ir.ui.view">
        <field name="name">local.transport.assignment.form</field>
        <field name="model">local.transport.assignment</field>
        <field name="arch" type="xml">
            <form string="Truck Assignment">
                <header>
                    <!-- Deliver button — only shown once the truck is In Transit -->
                    <button name="action_mark_delivered"
                            string="Mark as Delivered"
                            type="object"
                            class="btn-success"
                            invisible="state != 'in_transit'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="pending,in_transit,delivered"/>
                </header>

                <sheet>
                    <!-- Title: truck plate as heading -->
                    <div class="oe_title">
                        <label for="truck_plate" string="Truck"/>
                        <h1>
                            <field name="truck_plate"
                                   placeholder="e.g. AA-12345"
                                   readonly="trip_id.state in ('dispatched', 'in_transit', 'delivered', 'cancelled')"/>
                        </h1>
                    </div>

                    <!-- ── Truck Capacity ─────────────────────────────── -->
                    <group string="Truck Type">
                        <field name="capacity"
                               widget="radio"
                               readonly="trip_id.state in ('dispatched', 'in_transit', 'delivered', 'cancelled')"/>
                    </group>

                    <!-- ── Container 1 — always visible ──────────────── -->
                    <group string="Container 1">
                        <group>
                            <field name="container_id"
                                   domain="[('shipment_id', '=', shipment_id)]"
                                   options="{'no_create': True}"
                                   readonly="trip_id.state in ('dispatched', 'in_transit', 'delivered', 'cancelled')"/>
                            <field name="container_number" readonly="1"/>
                        </group>
                        <group>
                            <field name="container_size" readonly="1"/>
                            <field name="seal_number" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Container 2 — only shown for double trucks ── -->
                    <group string="Container 2" invisible="capacity != 'double'">
                        <group>
                            <field name="container2_id"
                                   domain="[('shipment_id', '=', shipment_id)]"
                                   options="{'no_create': True}"
                                   readonly="trip_id.state in ('dispatched', 'in_transit', 'delivered', 'cancelled')"/>
                            <field name="container2_number" readonly="1"/>
                        </group>
                        <group>
                            <field name="container2_size" readonly="1"/>
                            <field name="seal2_number" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Driver Details ─────────────────────────────── -->
                    <group string="Driver Details">
                        <group>
                            <field name="driver_name"
                                   placeholder="Full name"
                                   readonly="trip_id.state in ('dispatched', 'in_transit', 'delivered', 'cancelled')"/>
                            <field name="driver_phone"
                                   placeholder="+251..."
                                   readonly="trip_id.state in ('dispatched', 'in_transit', 'delivered', 'cancelled')"/>
                        </group>
                        <group>
                            <field name="driver_license"
                                   readonly="trip_id.state in ('dispatched', 'in_transit', 'delivered', 'cancelled')"/>
                        </group>
                    </group>

                    <!-- ── Delivery Info — date only shown when delivered ─ -->
                    <group string="Delivery">
                        <field name="actual_delivery_date"
                               invisible="state != 'delivered'"
                               readonly="1"/>
                        <field name="notes"
                               placeholder="Optional notes..."
                               readonly="trip_id.state in ('dispatched', 'in_transit', 'delivered', 'cancelled')"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         TRIP — LIST VIEW
    ══════════════════════════════════════════════════════════════════ -->
    <record id="view_local_transport_trip_list" model="ir.ui.view">
        <field name="name">local.transport.trip.list</field>
        <field name="model">local.transport.trip</field>
        <field name="arch" type="xml">
            <list string="Local Transport Trips" default_order="departure_date desc">
                <field name="reference"/>
                <field name="shipment_id"/>
                <field name="supplier_id"/>
                <field name="origin_location"/>
                <field name="destination_warehouse_id"/>
                <field name="departure_date"/>
                <field name="expected_arrival_date"/>
                <field name="assignment_count" string="Trucks"/>
                <field name="container_assignment_count" string="Containers"/>
                <field name="state"
                       widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-info="state == 'dispatched'"
                       decoration-warning="state == 'in_transit'"
                       decoration-success="state == 'delivered'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         TRIP — FORM VIEW
    ══════════════════════════════════════════════════════════════════ -->
    <record id="view_local_transport_trip_form" model="ir.ui.view">
        <field name="name">local.transport.trip.form</field>
        <field name="model">local.transport.trip</field>
        <field name="arch" type="xml">
            <form string="Local Transport Trip">
                <header>
                    <button name="action_dispatch" string="Dispatch Trucks"
                            type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_set_in_transit" string="Set In Transit"
                            type="object" class="btn-primary" invisible="state != 'dispatched'"/>
                    <button name="action_mark_delivered" string="Mark All Delivered"
                            type="object" class="btn-success"
                            invisible="state not in ('dispatched', 'in_transit')"/>
                    <button name="action_reset_to_draft" string="Reset to Draft"
                            type="object" class="btn-secondary"
                            invisible="state not in ('dispatched', 'cancelled')"/>
                    <button name="action_cancel" string="Cancel Trip"
                            type="object" class="btn-danger"
                            invisible="state in ('delivered', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,dispatched,in_transit,delivered"/>
                </header>

                <sheet>
                    <!-- Stats -->
                    <div class="oe_button_box" name="button_box">

                        <!-- ── Trucks stat button ─────────────────────────────
                             Clicking opens the list of LocalTransportAssignment
                             records (trucks) for this trip.
                        ──────────────────────────────────────────────────── -->
                        <button name="action_view_trucks"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-truck"
                                help="View truck assignments for this trip">
                            <field name="assignment_count"
                                   widget="statinfo"
                                   string="Trucks"/>
                        </button>

                        <!-- ── Containers stat button ─────────────────────────
                             Clicking opens the list of shipment.container records
                             assigned (across all truck slots) in this trip.
                        ──────────────────────────────────────────────────── -->
                        <button name="action_view_containers"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cube"
                                help="View containers assigned to this trip">
                            <field name="container_assignment_count"
                                   widget="statinfo"
                                   string="Containers"/>
                        </button>

                    </div>

                    <div class="oe_title">
                        <label for="reference" string="Transport Trip"/>
                        <h1><field name="reference" readonly="1"/></h1>
                    </div>

                    <!-- Linked Shipment -->
                    <group string="Linked Shipment">
                        <group>
                            <field name="shipment_id" readonly="state != 'draft'"
                                   options="{'no_create': True, 'no_edit': True}"/>
                            <field name="supplier_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="port_of_discharge" readonly="1"/>
                            <field name="shipment_actual_arrival" readonly="1"/>
                        </group>
                    </group>

                    <!-- Route -->
                    <group string="Route Details">
                        <group>
                            <field name="origin_location" readonly="state not in ('draft',)"
                                   placeholder="e.g. Mojo Port Terminal 2"/>
                            <field name="destination_warehouse_id"
                                   readonly="state not in ('draft',)"
                                   options="{'no_create': True, 'no_edit': True}"/>
                        </group>
                        <group>
                            <field name="departure_date" readonly="state not in ('draft',)"/>
                            <field name="expected_arrival_date" readonly="state not in ('draft',)"/>
                        </group>
                    </group>

                    <!-- Truck Assignments — summary list, each line opens the assignment form -->
                    <notebook>
                        <page string="Truck Assignments" name="assignments">
                            <field name="assignment_ids"
                                   context="{'default_trip_id': id}">
                                <list decoration-success="state == 'delivered'"
                                      decoration-warning="state == 'in_transit'"
                                      open_form_view="True"
                                      delete="0">
                                    <field name="capacity"/>
                                    <field name="container_number" string="Container 1" readonly="1"/>
                                    <field name="container2_number" string="Container 2" readonly="1"
                                           invisible="capacity != 'double'"/>
                                    <field name="truck_plate"/>
                                    <field name="driver_name"/>
                                    <field name="driver_phone" optional="show"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-muted="state == 'pending'"
                                           decoration-warning="state == 'in_transit'"
                                           decoration-success="state == 'delivered'"/>
                                    <button name="action_mark_delivered"
                                            string="Deliver"
                                            type="object"
                                            class="btn-sm btn-success"
                                            invisible="state != 'in_transit'"
                                            title="Mark this truck as delivered"/>
                                    <button name="action_delete_assignment"
                                            icon="fa-trash-o"
                                            type="object"
                                            class="btn-sm btn-link text-danger"
                                            invisible="state != 'pending'"
                                            confirm="Remove this truck assignment?"
                                            title="Remove this truck"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes_page">
                            <field name="notes"
                                   placeholder="Add internal notes about this transport trip..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         TRIP — KANBAN VIEW
    ══════════════════════════════════════════════════════════════════ -->
    <record id="view_local_transport_trip_kanban" model="ir.ui.view">
        <field name="name">local.transport.trip.kanban</field>
        <field name="model">local.transport.trip</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="reference"/>
                <field name="shipment_id"/>
                <field name="departure_date"/>
                <field name="assignment_count"/>
                <field name="container_assignment_count"/>
                <field name="origin_location"/>
                <field name="destination_warehouse_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="fw-bold text-primary"><field name="reference"/></div>
                            <div class="text-muted small">
                                <i class="fa fa-ship me-1"/><field name="shipment_id"/>
                            </div>
                            <div class="small mt-1">
                                <i class="fa fa-map-marker me-1"/><field name="origin_location"/>
                                <i class="fa fa-arrow-right mx-1"/>
                                <field name="destination_warehouse_id"/>
                            </div>
                            <div class="small">
                                <i class="fa fa-calendar me-1"/> Departs: <field name="departure_date"/>
                            </div>
                            <div class="small">
                                <i class="fa fa-truck me-1"/>
                                <field name="assignment_count"/> trucks /
                                <field name="container_assignment_count"/> containers
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         TRIP — SEARCH VIEW
    ══════════════════════════════════════════════════════════════════ -->
    <record id="view_local_transport_trip_search" model="ir.ui.view">
        <field name="name">local.transport.trip.search</field>
        <field name="model">local.transport.trip</field>
        <field name="arch" type="xml">
            <search string="Search Transport Trips">
                <field name="reference" string="Trip Reference"/>
                <field name="shipment_id" string="Shipment"/>
                <field name="supplier_id" string="Supplier"/>
                <field name="destination_warehouse_id" string="Destination Warehouse"/>
                <field name="assignment_ids" string="Truck Plate"
                       filter_domain="[('assignment_ids.truck_plate', 'ilike', self)]"/>
                <field name="assignment_ids" string="Driver Name"
                       filter_domain="[('assignment_ids.driver_name', 'ilike', self)]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="dispatched" string="Dispatched" domain="[('state','=','dispatched')]"/>
                <filter name="in_transit" string="In Transit" domain="[('state','=','in_transit')]"/>
                <filter name="delivered" string="Delivered" domain="[('state','=','delivered')]"/>
                <separator/>
                <filter name="all_delivered" string="Fully Delivered"
                        domain="[('all_delivered','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_shipment" string="Shipment" context="{'group_by': 'shipment_id'}"/>
                    <filter name="group_warehouse" string="Destination Warehouse"
                            context="{'group_by': 'destination_warehouse_id'}"/>
                    <filter name="group_date" string="Departure Month"
                            context="{'group_by': 'departure_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         WINDOW ACTION + MENU
    ══════════════════════════════════════════════════════════════════ -->
    <record id="action_local_transport_trip" model="ir.actions.act_window">
        <field name="name">Local Transport Trips</field>
        <field name="res_model">local.transport.trip</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_local_transport_trip_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No transport trips yet.</p>
            <p>Create a trip when a shipment arrives and trucks are dispatched to bring containers to the warehouse.</p>
        </field>
    </record>

    <menuitem id="menu_local_transport" name="Local Transport" parent="menu_shipment_root"
              action="action_local_transport_trip" sequence="30"/>

</odoo>
