<?xml version="1.0" encoding="utf-8"?>
<!-- shipment_tracking/views/shipment_carrier_views.xml -->
<odoo>

    <!-- ══ CARRIER — LIST VIEW (editable, drag to reorder) ══ -->
    <record id="view_shipment_carrier_list" model="ir.ui.view">
        <field name="name">shipment.carrier.list</field>
        <field name="model">shipment.carrier</field>
        <field name="arch" type="xml">
            <list string="Carriers" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="notes"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ══ CARRIER — FORM VIEW ══ -->
    <record id="view_shipment_carrier_form" model="ir.ui.view">
        <field name="name">shipment.carrier.form</field>
        <field name="model">shipment.carrier</field>
        <field name="arch" type="xml">
            <form string="Carrier">
                <sheet>
                    <group>
                        <field name="name" placeholder="e.g. Maersk, MSC, CMA CGM"/>
                        <field name="sequence"/>
                        <field name="notes" placeholder="Optional description..."/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══ CARRIER — SEARCH VIEW ══ -->
    <record id="view_shipment_carrier_search" model="ir.ui.view">
        <field name="name">shipment.carrier.search</field>
        <field name="model">shipment.carrier</field>
        <field name="arch" type="xml">
            <search string="Search Carriers">
                <field name="name"/>
                <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- ══ ACTION ══ -->
    <record id="action_shipment_carrier" model="ir.actions.act_window">
        <field name="name">Carriers</field>
        <field name="res_model">shipment.carrier</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_shipment_carrier_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Carrier.</p>
            <p>Carriers are fully customizable — add, rename, reorder, or archive
               them as your shipping lines change. They appear as the "Carrier /
               Shipping Line" dropdown on every Shipment record.</p>
        </field>
    </record>

    <!-- Reuses the existing "Configuration" menu defined in
         shipment_cost_stage_views.xml (menu_shipment_costs_configuration),
         which already sits under the root "Shipment Tracking" menu. -->
    <menuitem id="menu_shipment_carrier" name="Carriers"
              parent="menu_shipment_costs_configuration"
              action="action_shipment_carrier" sequence="5"/>

</odoo>
