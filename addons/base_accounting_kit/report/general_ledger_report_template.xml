<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_general_ledger">
        <t t-call="web.html_container">
            <t t-set="data_report_margin_top" t-value="12"/>
            <t t-set="data_report_header_spacing" t-value="9"/>
            <t t-set="data_report_dpi" t-value="110"/>
            <t t-call="web.internal_layout">
                <div class="page"><br/>
                    <h2><span t-esc="env.company.name"/>: General ledger</h2>
                    <div class="row mt32">
                        <div class="col-4">
                            <strong>Journals:</strong>
                              <p t-esc="', '.join([ lt or '' for lt in print_journal ])"/>
                        </div>
                        <div class="col-4">
                            <strong>Display Account</strong>
                            <p>
                                <span t-if="data['display_account'] == 'all'">All accounts'</span>
                                <span t-if="data['display_account'] == 'movement'">With movements</span>
                                <span t-if="data['display_account'] == 'not_zero'">With balance not equal to zero</span>
                            </p>
                        </div>
                        <div class="col-4">
                            <strong>Target Moves:</strong>
                            <p t-if="data['target_move'] == 'all'">All Entries</p>
                            <p t-if="data['target_move'] == 'posted'">All Posted Entries</p>
                        </div>
                    </div>
                    <div class="row mb32">
                        <div class="col-4">
                            <strong>Sorted By:</strong>
                            <p t-if="data['sortby'] == 'sort_date'">Date</p>
                            <p t-if="data['sortby'] == 'sort_journal_partner'">Journal and Partner</p>
                        </div>
                        <div class="col-4">
                            <t t-if="data['date_from']"><strong>Date from :</strong> <span t-esc="data['date_from']"/><br/></t>
                            <t t-if="data['date_to']"><strong>Date to :</strong> <span t-esc="data['date_to']"/></t>
                        </div>
                    </div>

<table class="table table-sm"
       style="border-collapse:collapse;
              width:100%;
              font-size:12px;">

    <!-- ===================================================== -->
    <!-- TABLE HEADER -->
    <!-- ===================================================== -->

    <thead>

        <tr style="
            background:#d9d9d9;
            border:1px solid #999;
            font-weight:bold;
        ">

            <th style="padding:7px; border:1px solid #999;">
                Date
            </th>

            <th style="padding:7px; border:1px solid #999;" t-if="data['show_journal']">
                JRNL
            </th>

            <th style="padding:7px; border:1px solid #999;" t-if="data['show_partner']">
                Partner
            </th>

            <th style="padding:7px; border:1px solid #999;" t-if="data['show_ref']">
                Ref
            </th>

            <th style="padding:7px; border:1px solid #999;" t-if="data['show_move']">
                Move
            </th>

            <th style="padding:7px; border:1px solid #999;" t-if="data['show_entry_label']">
                Entry Label
            </th>

            <th style="
                padding:7px;
                border:1px solid #999;
                border-left:2px solid #666;
                text-align:right;
            ">
                Debit
            </th>

            <th style="
                padding:7px;
                border:1px solid #999;
                border-left:2px solid #666;
                text-align:right;
            ">
                Credit
            </th>

            <th style="
                padding:7px;
                border:1px solid #999;
                border-left:2px solid #666;
                text-align:right;
            ">
                Balance
            </th>

        </tr>

    </thead>

    <!-- ===================================================== -->
    <!-- BODY -->
    <!-- ===================================================== -->

    <tbody>

        <t t-foreach="Accounts" t-as="account">

            <!-- ============================================= -->
            <!-- ACCOUNT HEADER -->
            <!-- ============================================= -->

            <tr style="
                background:#ececec;
                font-weight:bold;
                border-top:2px solid #666;
            ">

                <td t-att-colspan="visible_info_columns"
                    style="padding:8px; border:1px solid #bbb;">

                    <span t-esc="account['code']"/>
                    -
                    <span t-esc="account['name']"/>

                </td>

                <td class="text-end"
                    style="
                        padding:8px;
                        border:1px solid #bbb;
                        border-left:2px solid #666;
                    ">

                    <span t-esc="account['debit']"
                          t-options="{
                            'widget':'monetary',
                            'display_currency': env.company.currency_id
                          }"/>

                </td>

                <td class="text-end"
                    style="
                        padding:8px;
                        border:1px solid #bbb;
                        border-left:2px solid #666;
                    ">

                    <span t-esc="account['credit']"
                          t-options="{
                            'widget':'monetary',
                            'display_currency': env.company.currency_id
                          }"/>

                </td>

                <td class="text-end"
                    style="
                        padding:8px;
                        border:1px solid #bbb;
                        border-left:2px solid #666;
                        font-weight:bold;
                    ">

                    <span t-esc="account['balance']"
                          t-options="{
                            'widget':'monetary',
                            'display_currency': env.company.currency_id
                          }"/>

                </td>

            </tr>

            <!-- ============================================= -->
            <!-- INITIAL BALANCE -->
            <!-- ============================================= -->   
            
            <t t-if="data['initial_balance']">

            <tr style="
                background:#f5f5f5;
                font-weight:bold;
            ">

                <td t-att-colspan="visible_info_columns + 2"
                    class="text-end">

                    Initial Balance

                </td>

                <td class="text-end">

                    <span t-esc="account['initial_balance']"
                        t-options="{
                            'widget':'monetary',
                            'display_currency': env.company.currency_id
                        }"/>

                </td>

            </tr>

            </t>



            <!-- ============================================= -->
            <!-- MOVE LINES -->
            <!-- ============================================= -->

            <tr t-foreach="account['move_lines']"
                t-as="line">

                <td style="padding:6px; border:1px solid #ddd;">
                    <span t-esc="line['ldate']"/>
                </td>

                <td style="padding:6px; border:1px solid #ddd;" t-if="data['show_journal']">
                    <span t-esc="line['lcode']"/>
                </td>

                <td style="padding:6px; border:1px solid #ddd;" t-if="data['show_partner']">
                    <span t-esc="line['partner_name']"/>
                </td>

                <td style="padding:6px; border:1px solid #ddd;" t-if="data['show_ref']">

                    <span t-if="line['lref']"
                          t-esc="line['lref']"/>

                </td>

                <td style="padding:6px; border:1px solid #ddd;" t-if="data['show_move']">
                    <span t-esc="line['move_name']"/>
                </td>

               
                <td class="text-end"
                    style="
                        padding:6px;
                        border:1px solid #ddd;
                        border-left:2px solid #999;
                    ">

                    <span t-esc="line['debit']"
                          t-options="{
                            'widget':'monetary',
                            'display_currency': env.company.currency_id
                          }"/>

                </td>

                <td class="text-end"
                    style="
                        padding:6px;
                        border:1px solid #ddd;
                        border-left:2px solid #999;
                    ">

                    <span t-esc="line['credit']"
                          t-options="{
                            'widget':'monetary',
                            'display_currency': env.company.currency_id
                          }"/>

                </td>

                <td class="text-end"
                    style="
                        padding:6px;
                        border:1px solid #ddd;
                        border-left:2px solid #999;
                    ">

                    <span t-esc="line['balance']"
                          t-options="{
                            'widget':'monetary',
                            'display_currency': env.company.currency_id
                          }"/>

                </td>

            </tr>

            <!-- ============================================= -->
            <!-- ENDING BALANCE -->
            <!-- ============================================= -->

            <tr style="
                background:#f5f5f5;
                font-weight:bold;
                border-top:2px solid #999;
            ">

                <td t-att-colspan="visible_info_columns + 2"
                    class="text-end"
                    style="padding:8px; border:1px solid #bbb;">

                    Ending Balance

                </td>

                <td class="text-end"
                    style="
                        padding:8px;
                        border:1px solid #bbb;
                        border-left:2px solid #666;
                        font-size:13px;
                    ">

                    <span t-esc="account['ending_balance']"
                          t-options="{
                            'widget':'monetary',
                            'display_currency': env.company.currency_id
                          }"/>

                </td>

            </tr>

        </t>

    </tbody>

</table>

                </div>
            </t>
        </t>
    </template>
</odoo>
