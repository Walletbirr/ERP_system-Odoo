<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_trial_balance">

        <t t-call="web.html_container">

            <t t-set="data_report_margin_top" t-value="12"/>
            <t t-set="data_report_header_spacing" t-value="9"/>
            <t t-set="data_report_dpi" t-value="110"/>

            <t t-call="web.internal_layout">

                <div class="page">

                    <br/>

                    <!-- TITLE -->
                    <h2>
                        <span t-esc="env.company.name"/>:
                        Trial Balance
                    </h2>

                    <!-- FILTER SECTION -->
                    <div class="row mt32">

                        <div class="col-4">

                            <strong>Display Account:</strong>

                            <p>

                                <span t-if="data['display_account'] == 'all'">
                                    All accounts
                                </span>

                                <span t-if="data['display_account'] == 'movement'">
                                    With movements
                                </span>

                                <span t-if="data['display_account'] == 'not_zero'">
                                    With balance not equal to zero
                                </span>

                            </p>

                        </div>

                        <div class="col-4">

                            <p>

                                <t t-if="data['date_from']">

                                    <strong>Date from :</strong>

                                    <span t-esc="data['date_from']"/>

                                    <br/>

                                </t>

                                <t t-if="data['date_to']">

                                    <strong>Date to :</strong>

                                    <span t-esc="data['date_to']"/>

                                </t>

                            </p>

                        </div>

                        <div class="col-4">

                            <strong>Target Moves:</strong>

                            <p>

                                <span t-if="data['target_move'] == 'all'">
                                    All Entries
                                </span>

                                <span t-if="data['target_move'] == 'posted'">
                                    All Posted Entries
                                </span>

                            </p>

                        </div>

                    </div>

                    <!-- TABLE -->
                    <table class="table table-sm"
                           style="width:100%;
                                  border-collapse:collapse;
                                  margin-top:20px;">

                        <!-- HEADER -->
                        <thead>

                            <tr style="
                                background:#d9d9d9;
                                border-bottom:2px solid #999;
                            ">

                                <th style="
                                    padding:8px;
                                    border:1px solid #c0c0c0;
                                ">
                                    Code
                                </th>

                                <th style="
                                    padding:8px;
                                    border:1px solid #c0c0c0;
                                ">
                                    Account
                                </th>

                                <th class="text-end"
                                    style="
                                        padding:8px;
                                        border:1px solid #c0c0c0;
                                    ">
                                    Debit
                                </th>

                                <th class="text-end"
                                    style="
                                        padding:8px;
                                        border:1px solid #c0c0c0;
                                    ">
                                    Credit
                                </th>

                            </tr>

                        </thead>

                        <!-- BODY -->
                        <tbody>

                            <tr t-foreach="Accounts"
                                t-as="account"
                                style="border-bottom:1px solid #e5e5e5;">

                                <!-- CODE -->
                                <td style="padding:7px;">

                                    <span t-esc="account['code']"/>

                                </td>

                                <!-- ACCOUNT -->
                                <td style="padding:7px;">

                                    <span t-esc="account['name']"/>

                                </td>

                                <!-- DEBIT -->
                                <td class="text-end"
                                    style="
                                        padding:7px;
                                        border-left:2px solid #d0d0d0;
                                    ">

                                    <span t-esc="account['debit']"
                                          t-options="{
                                              'widget': 'monetary',
                                              'display_currency':
                                              env.company.currency_id
                                          }"/>

                                </td>

                                <!-- CREDIT -->
                                <td class="text-end"
                                    style="
                                        padding:7px;
                                        border-left:2px solid #d0d0d0;
                                    ">

                                    <span t-esc="account['credit']"
                                          t-options="{
                                              'widget': 'monetary',
                                              'display_currency':
                                              env.company.currency_id
                                          }"/>

                                </td>

                            </tr>
                            <!-- TOTALS -->

<tr style="
    border-top:2px solid #999;
    font-weight:bold;
">

    <td></td>

    <td style="
        padding:8px;
        text-align:right;
    ">
        Total
    </td>

    <!-- TOTAL DEBIT -->

    <td class="text-end"
        style="
            padding:8px;
            border-left:2px solid #d0d0d0;
        ">

        <span t-esc="total_debit"
              t-options="{
                  'widget':'monetary',
                  'display_currency':
                  env.company.currency_id
              }"/>

    </td>

    <!-- TOTAL CREDIT -->

    <td class="text-end"
        style="
            padding:8px;
            border-left:2px solid #d0d0d0;
        ">

        <span t-esc="total_credit"
              t-options="{
                  'widget':'monetary',
                  'display_currency':
                  env.company.currency_id
              }"/>

    </td>

</tr>

                        </tbody>

                    </table>

                </div>

            </t>

        </t>

    </template>

</odoo>