<odoo>
    <record id="view_product_form_inherit_vehicle" model="ir.ui.view">
        <field name="name">product.template.form.vehicle</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook/page[@name='general_information']" position="inside">
                <group string="Vehicle Info">
                    <field name="is_vehicle"/>
                    <field name="engine_number"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>