<data>
    <record id="view_move_line_form" model="ir.ui.view">
        <field name="name">stock.move.line.form</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="date_deadline" />
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree_detailed" model="ir.ui.view">
        <field name="name">stock.move.line.tree.detailed</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree_detailed" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='scheduled_date']" position="after">
                <field name="date_deadline" widget="remaining_days" optional="hide" />
            </xpath>
            <xpath expr="//field[@name='scheduled_date']" position="attributes">
                <attribute name="widget">remaining_days</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree" model="ir.ui.view">
        <field name="name">stock.move.line.tree</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="date_deadline" widget="remaining_days" optional="hide" />
                <field name="scheduled_date" widget="remaining_days" optional="hide" />
            </xpath>
        </field>
    </record>

    <record id="stock_move_line_view_search" model="ir.ui.view">
        <field name="name">stock.move.line.search</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.stock_move_line_view_search" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='date']" position="before">
                <filter
                    string="Scheduled Date"
                    name="scheduled_date"
                    date="scheduled_date"
                />
                <filter
                    string="Today"
                    name="today"
                    domain="[('scheduled_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0, 0, 0)).to_utc()), ('scheduled_date', '&lt;', datetime.datetime.combine(context_today() + relativedelta(days=1), datetime.time(0, 0, 0)).to_utc())]"
                />
                <filter
                    string="Tomorrow"
                    name="tomorrow"
                    domain="[('scheduled_date', '&gt;=', datetime.datetime.combine(context_today() + relativedelta(days=1), datetime.time(0, 0, 0)).to_utc()), ('scheduled_date', '&lt;', datetime.datetime.combine(context_today() + relativedelta(days=2), datetime.time(0, 0, 0)).to_utc())]"
                />
                <separator />
            </xpath>
            <xpath expr="//group/filter[@name='by_date']" position="before">
                <filter
                    string="Scheduled Date"
                    name="by_date_schedule"
                    domain="[]"
                    context="{'group_by': 'scheduled_date'}"
                />
                <filter
                    string="Deadline"
                    name="by_date_deadline"
                    domain="[]"
                    context="{'group_by': 'date_deadline'}"
                />
            </xpath>
        </field>
    </record>
</data>
