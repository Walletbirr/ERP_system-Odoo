<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view: read-only, report-style -->
    <record id="view_partner_credit_list" model="ir.ui.view">
        <field name="name">res.partner.credit.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Customer Credit" create="false" delete="false" edit="false">
                <field name="name"/>
                <field name="phone" optional="hide"/>
                <field name="email" optional="hide"/>
                <field name="sale_order_count" string="Orders"/>
                <field name="x_total_invoiced" string="Total Invoiced" sum="Total Invoiced"/>
                <field name="x_credit_amount_paid" string="Amount Paid" sum="Amount Paid"/>
                <field name="credit" string="Outstanding Credit" sum="Outstanding Credit"
                       decoration-danger="credit &gt; 0"/>
                <field name="x_remaining_balance" string="Remaining Balance" sum="Remaining Balance"
                       decoration-danger="x_remaining_balance &gt; 0"/>
            </list>
        </field>
    </record>

    <!-- Search view: filter customers with/without outstanding credit -->
    <record id="view_partner_credit_search" model="ir.ui.view">
        <field name="name">res.partner.credit.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Customer Credit Search">
                <field name="name"/>
                <filter string="With Outstanding Credit" name="with_credit"
                        domain="[('credit', '&gt;', 0)]"/>
                <filter string="Settled (No Credit)" name="no_credit"
                         domain="[('credit', '=', 0)]"/>
                <group expand="0" string="Group By">
                    <filter string="Country" name="group_country"
                            context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_partner_credit_report" model="ir.actions.act_window">
        <field name="name">Customer Credit</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_partner_credit_search"/>
        <field name="domain">[('customer_rank', '&gt;', 0)]</field>
        <field name="context">{'search_default_with_credit': 1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_partner_credit_list')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No customers with outstanding credit right now.
            </p>
            <p>
                This report lists customers who still owe money on invoiced sales
                orders, calculated automatically from existing sales, invoice and
                payment data.
            </p>
        </field>
    </record>

    <!-- Menu item under Sales > Reporting -->
    <menuitem id="menu_partner_credit_report"
              name="Customer Credit"
              parent="sale.menu_sale_report"
              action="action_partner_credit_report"
              sequence="100"/>

</odoo>
